# T-13 (docs/THREAT_MODEL.md): minimum release age ("cooldown").
# Do not install a package version published less than 7 days ago, so a freshly
# published malicious release is not pulled before the community detects and
# yanks it. Honored by npm >= 11.10; gates `npm install` / `npm update`
# resolution — frozen `npm ci` is unaffected. Value is in DAYS (npm semantics;
# pnpm/bun equivalents use minutes/seconds).
min-release-age=7

# Older npm would silently ignore min-release-age, letting a lockfile update
# bypass the cooldown. engine-strict turns the engines floor in package.json
# (npm >= 11.10) into a hard install-time error instead. Upgrade with:
# npm install -g npm@^11.10
engine-strict=true
